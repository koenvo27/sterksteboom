---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import EventCard from "../../components/EventCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("events", ({ data }) => data.published);
const upcoming = allEvents
  .filter((e) => e.data.status === "Aankomend")
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const past = allEvents
  .filter((e) => e.data.status === "Afgelopen")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title="Acties"
  description="Alle acties en evenementen van De Sterkste Boom van Rendestede."
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-14 sm:py-20">
    <Breadcrumbs items={[{ label: "Acties" }]} />
    <h1 class="font-display text-4xl sm:text-5xl font-semibold text-antraciet-900">Acties</h1>
    <p class="mt-4 text-antraciet-700 max-w-2xl">
      Naast de sportieve uitdagingen organiseren we ook kleinere acties en evenementen.
    </p>

    <section class="mt-10">
      <h2 class="font-display text-2xl font-semibold text-antraciet-900 mb-6">Aankomend</h2>
      {upcoming.length === 0 ? (
        <EmptyState message="Er zijn momenteel geen publieke acties gepland. Kom later zeker nog eens terug." />
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {upcoming.map((event) => (
            <EventCard
              title={event.data.title}
              type={event.data.type}
              summary={event.data.summary}
              date={event.data.date}
              location={event.data.location}
              status={event.data.status}
              externalUrl={event.data.externalUrl}
            />
          ))}
        </div>
      )}
    </section>

    {past.length > 0 && (
      <section class="mt-16">
        <h2 class="font-display text-2xl font-semibold text-antraciet-900 mb-6">Afgelopen</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {past.map((event) => (
            <EventCard
              title={event.data.title}
              type={event.data.type}
              summary={event.data.summary}
              date={event.data.date}
              location={event.data.location}
              status={event.data.status}
              externalUrl={event.data.externalUrl}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
