---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ChallengeCard from "../../components/ChallengeCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCollection } from "astro:content";

const challenges = (await getCollection("challenges", ({ data }) => data.published)).sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);
---

<Layout
  title="Uitdagingen"
  description="De sportieve uitdagingen van De Sterkste Boom van Rendestede, op weg naar De 1000 km voor Kom op tegen Kanker."
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-14 sm:py-20">
    <Breadcrumbs items={[{ label: "De uitdagingen" }]} />
    <h1 class="font-display text-4xl sm:text-5xl font-semibold text-antraciet-900">De uitdagingen</h1>
    <p class="mt-4 text-antraciet-700 max-w-2xl">
      Elke uitdaging is een stap richting het grote doel: in mei 2027 mee in De 1000 km
      voor Kom op tegen Kanker. Van de eerste beklimming tot de laatste kilometer.
    </p>

    <div class="mt-10 grid gap-6">
      {challenges.length === 0 ? (
        <EmptyState message="Binnenkort verschijnen hier de eerste uitdagingen." />
      ) : (
        challenges.map((challenge) => (
          <ChallengeCard
            title={challenge.data.title}
            summary={challenge.data.summary}
            date={challenge.data.date}
            location={challenge.data.location}
            status={challenge.data.status}
            dateLabel={challenge.data.dateLabel}
            href={`/uitdagingen/${challenge.id}`}
          />
        ))
      )}
    </div>
  </div>
</Layout>
