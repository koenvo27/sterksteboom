---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import DonationButton from "../../components/DonationButton.astro";
import StructuredData from "../../components/StructuredData.astro";
import Countdown from "../../components/Countdown.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { siteConfig } from "../../data/site-config";

export async function getStaticPaths() {
  const challenges = await getCollection("challenges", ({ data }) => data.published);
  return challenges.map((challenge) => ({
    params: { slug: challenge.id },
    props: { challenge },
  }));
}

interface Props {
  challenge: CollectionEntry<"challenges">;
}

const { challenge } = Astro.props;
const { Content } = await render(challenge);
const pageUrl = new URL(`/uitdagingen/${challenge.id}`, siteConfig.url).toString();
const formattedDate = challenge.data.date.toLocaleDateString("nl-BE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const isUpcoming = challenge.data.date.getTime() > Date.now();
const isoDate = challenge.data.date.toISOString().slice(0, 10);
---

<Layout
  title={challenge.data.seoTitle ?? challenge.data.title}
  description={challenge.data.seoDescription ?? challenge.data.summary}
  type="article"
>
  <StructuredData
    kind="Event"
    name={challenge.data.title}
    description={challenge.data.summary}
    startDate={challenge.data.date.toISOString()}
    location={challenge.data.location}
    url={pageUrl}
  />

  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-14 sm:py-20">
    <Breadcrumbs
      items={[{ label: "Uitdagingen", href: "/uitdagingen" }, { label: challenge.data.title }]}
    />

    <span class="inline-block text-xs font-semibold uppercase tracking-wide text-bos-600 mb-2">
      {challenge.data.status}
    </span>
    <h1 class="font-display text-3xl sm:text-4xl font-semibold text-antraciet-900">
      {challenge.data.title}
    </h1>
    <p class="mt-3 text-sm text-antraciet-500">
      {formattedDate} · {challenge.data.location}
    </p>
    <p class="mt-5 text-lg text-antraciet-700">{challenge.data.summary}</p>

    {isUpcoming && (
      <div class="mt-6">
        <Countdown date={isoDate} label={challenge.data.title} />
      </div>
    )}

    {challenge.data.poster && (
      <img
        src={challenge.data.poster}
        alt={`Affiche: ${challenge.data.title}`}
        class="mt-8 w-full rounded-card border border-beige-200 shadow-sm"
        loading="lazy"
      />
    )}

    <div class="mt-10 prose-content max-w-none text-antraciet-800 leading-relaxed
                [&_h2]:font-display [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:text-antraciet-900 [&_h2]:mt-10 [&_h2]:mb-3
                [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-1 [&_li]:marker:text-goud-500
                [&_a]:text-goud-700 [&_a]:underline
                [&_p]:mb-4">
      <Content />
    </div>

    <div class="mt-12 flex justify-center">
      <DonationButton />
    </div>

    <div class="mt-12 border-t border-beige-200 pt-8">
      <ShareButtons url={pageUrl} title={challenge.data.title} />
    </div>
  </article>
</Layout>
