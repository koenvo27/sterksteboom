---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import DonationButton from "../components/DonationButton.astro";

const manieren = [
  {
    titel: "Financiële steun",
    tekst:
      "Een bijdrage die integraal richting het goede doel gaat. Elke euro helpt om het streefbedrag voor Kom op tegen Kanker te bereiken.",
  },
  {
    titel: "Materiële of logistieke steun",
    tekst:
      "Denk aan bevoorrading, materiaal, drukwerk of hulp bij de organisatie van een actie of evenement.",
  },
  {
    titel: "Zichtbaarheid en netwerk",
    tekst:
      "Help het project bekend maken via je eigen kanalen en netwerk, zodat meer mensen mee in beweging komen.",
  },
];
---

<Layout
  title="Word partner"
  description="Word partner van De Sterkste Boom van Rendestede en steun mee de strijd tegen kanker."
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-14 sm:py-20">
    <Breadcrumbs items={[{ label: "Word partner" }]} />
    <h1 class="font-display text-4xl sm:text-5xl font-semibold text-antraciet-900">Word partner</h1>
    <p class="mt-4 text-antraciet-700">
      Bedrijven en organisaties kunnen op verschillende manieren mee hun schouders zetten onder
      De Sterkste Boom van Rendestede. Samen maken we meer mogelijk voor Kom op tegen Kanker.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {manieren.map((manier) => (
        <div class="rounded-card border border-beige-200 bg-white p-6">
          <h2 class="font-display text-lg font-semibold text-antraciet-900">{manier.titel}</h2>
          <p class="mt-2 text-sm text-antraciet-700">{manier.tekst}</p>
        </div>
      ))}
    </div>

    <div class="mt-16">
      <SectionHeader
        eyebrow="Interesse?"
        title="Laat het ons weten"
        description="Stuur een bericht met je vraag of voorstel. Ik neem persoonlijk contact met je op om de mogelijkheden te bespreken."
      />
      <div class="mt-8">
        <ContactForm
          subject="Ik wil partner worden van De Sterkste Boom van Rendestede"
          categories={["Financiële steun", "Materiële of logistieke steun", "Zichtbaarheid en netwerk", "Iets anders"]}
        />
      </div>
    </div>

    <div class="mt-16 rounded-card bg-beige-100 border border-beige-200 p-8 text-center">
      <p class="text-antraciet-700">
        Liever meteen een gift doen? Dat kan altijd via de officiële actiepagina van Kom op tegen Kanker.
      </p>
      <div class="mt-5 flex justify-center">
        <DonationButton />
      </div>
    </div>
  </div>
</Layout>
