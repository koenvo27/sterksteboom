---
import fundraising from "../data/fundraising.json";
import DonationButton from "./DonationButton.astro";

const { raised, goal, lastUpdated, showProgress } = fundraising;
const percentage = goal > 0 ? Math.min(100, Math.round((raised / goal) * 100)) : 0;
const formattedDate = new Date(lastUpdated).toLocaleDateString("nl-BE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const eur = new Intl.NumberFormat("nl-BE", {
  style: "currency",
  currency: "EUR",
  maximumFractionDigits: 0,
});
---

<section class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
  <div class="relative overflow-hidden rounded-card bg-beige-100 border border-beige-200 p-6 sm:p-10">
    <img
      src="/images/tree-mark.webp"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute -right-12 -bottom-20 w-72 opacity-[0.06]"
    />
    <div class="relative grid gap-8 md:grid-cols-[auto_1fr] items-center">
    <!-- Jaarring-voortgangscirkel: hetzelfde motief als de hero, nu als data -->
    <div class="relative w-40 h-40 sm:w-48 sm:h-48 mx-auto">
      <svg viewBox="0 0 200 200" class="w-full h-full -rotate-90">
        <circle cx="100" cy="100" r="88" fill="none" stroke="#e9dfc7" stroke-width="14" />
        {showProgress && (
          <circle
            cx="100"
            cy="100"
            r="88"
            fill="none"
            stroke="#e0a52e"
            stroke-width="14"
            stroke-linecap="round"
            stroke-dasharray={`${(percentage / 100) * 2 * Math.PI * 88} ${2 * Math.PI * 88}`}
          />
        )}
      </svg>
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <span class="font-display text-3xl font-semibold text-antraciet-900">{percentage}%</span>
        <span class="text-xs text-antraciet-700">van het doel</span>
      </div>
    </div>

    <div>
      <h2 class="font-display text-2xl sm:text-3xl font-semibold text-antraciet-900">Fondsenwerving</h2>
      <p class="mt-2 text-antraciet-700">
        Opgehaald: <strong class="text-antraciet-900">{eur.format(raised)}</strong>
        {" "}van de <strong class="text-antraciet-900">{eur.format(goal)}</strong> doelstelling.
      </p>
      {showProgress && (
        <div
          class="mt-4 h-2.5 w-full overflow-hidden rounded-full bg-beige-200"
          role="progressbar"
          aria-valuenow={percentage}
          aria-valuemin="0"
          aria-valuemax="100"
          aria-label={`Voortgang fondsenwerving: ${percentage}% van het doel`}
        >
          <div class="h-full rounded-full bg-goud-500" style={`width:${percentage}%`}></div>
        </div>
      )}
      <p class="mt-3 text-sm text-antraciet-500">Laatst bijgewerkt op {formattedDate}.</p>
      <div class="mt-6">
        <DonationButton />
      </div>
    </div>
    </div>
  </div>
</section>
