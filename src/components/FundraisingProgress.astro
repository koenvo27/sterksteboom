---
import fundraising from "../data/fundraising.json";
import DonationButton from "./DonationButton.astro";

const { raised, goal, lastUpdated, showProgress } = fundraising;
// 'goal' (€5.500) is het startdoel dat nodig is om deel te nemen.
// 'stretchGoal' (€10.000) is de ambitie waar we samen naartoe werken.
const ambition = "stretchGoal" in fundraising ? fundraising.stretchGoal : goal;

// De ring toont de voortgang richting het startdoel (deelnamebedrag).
const milestonePct = goal > 0 ? Math.min(100, Math.round((raised / goal) * 100)) : 0;
// De balk toont de voortgang richting de ambitie.
const ambitionPct = ambition > 0 ? Math.min(100, Math.round((raised / ambition) * 100)) : 0;
const milestoneReached = raised >= goal;

const formattedDate = new Date(lastUpdated).toLocaleDateString("nl-BE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const eur = new Intl.NumberFormat("nl-BE", {
  style: "currency",
  currency: "EUR",
  maximumFractionDigits: 0,
});

// Positie van de €5.500-markering op de balk naar €10.000 toe.
const milestoneMarkerPct = ambition > 0 ? Math.min(100, Math.round((goal / ambition) * 100)) : 0;
---

<section class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
  <div class="relative overflow-hidden rounded-card bg-beige-100 border border-beige-200 p-6 sm:p-10">
    <img
      src="/images/tree-mark.webp"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute -right-12 -bottom-20 w-72 opacity-[0.06]"
    />
    <div class="relative grid gap-8 md:grid-cols-[auto_1fr] items-center">
    <!-- Jaarring-voortgangscirkel: hetzelfde motief als de hero, nu als data -->
    <div class="relative w-40 h-40 sm:w-48 sm:h-48 mx-auto">
      <svg viewBox="0 0 200 200" class="w-full h-full -rotate-90">
        <circle cx="100" cy="100" r="88" fill="none" stroke="#e9dfc7" stroke-width="14" />
        {showProgress && (
          <circle
            cx="100"
            cy="100"
            r="88"
            fill="none"
            stroke="#e0a52e"
            stroke-width="14"
            stroke-linecap="round"
            stroke-dasharray={`${(milestonePct / 100) * 2 * Math.PI * 88} ${2 * Math.PI * 88}`}
          />
        )}
      </svg>
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <span class="font-display text-3xl font-semibold text-antraciet-900">{milestonePct}%</span>
        <span class="text-xs text-antraciet-700">van het startdoel</span>
      </div>
    </div>

    <div>
      <p class="font-accent text-2xl text-bos-600">💛 Samen richting {eur.format(ambition)}</p>
      <h2 class="mt-1 font-display text-2xl sm:text-3xl font-semibold text-antraciet-900">Fondsenwerving</h2>
      <p class="mt-3 text-antraciet-700">
        Tot nu toe samen opgehaald: <strong class="text-antraciet-900">{eur.format(raised)}</strong>.
      </p>

      <!-- Twee heldere doelen: het startdoel en de ambitie -->
      <dl class="mt-5 grid gap-4 sm:grid-cols-2">
        <div class="rounded-lg border border-beige-200 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-antraciet-500">
            Startdoel {milestoneReached ? "✔ behaald" : ""}
          </dt>
          <dd class="mt-1 font-display text-2xl font-semibold text-antraciet-900">{eur.format(goal)}</dd>
          <dd class="mt-1 text-sm text-antraciet-700">
            Het bedrag dat nodig is om deel te nemen aan De 1000 km.
          </dd>
        </div>
        <div class="rounded-lg border border-goud-200 bg-goud-50 p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-goud-700">Onze ambitie</dt>
          <dd class="mt-1 font-display text-2xl font-semibold text-antraciet-900">{eur.format(ambition)}</dd>
          <dd class="mt-1 text-sm text-antraciet-700">
            Waar we samen naartoe willen voor Kom op tegen Kanker.
          </dd>
        </div>
      </dl>

      {showProgress && (
        <div class="mt-6">
          <div
            class="relative h-2.5 w-full overflow-hidden rounded-full bg-beige-200"
            role="progressbar"
            aria-valuenow={ambitionPct}
            aria-valuemin="0"
            aria-valuemax="100"
            aria-label={`Voortgang richting de ambitie van ${eur.format(ambition)}: ${ambitionPct}%`}
          >
            <div class="h-full rounded-full bg-goud-500" style={`width:${ambitionPct}%`}></div>
          </div>
          <!-- Markering van het startdoel op weg naar de ambitie -->
          <div class="relative mt-1 h-4 text-xs text-antraciet-500">
            <span
              class="absolute -translate-x-1/2 whitespace-nowrap"
              style={`left:${milestoneMarkerPct}%`}
            >
              ↑ {eur.format(goal)}
            </span>
            <span class="absolute right-0">{eur.format(ambition)}</span>
          </div>
        </div>
      )}

      <p class="mt-5 text-sm text-antraciet-500">Laatst bijgewerkt op {formattedDate}.</p>

      <div class="mt-6">
        <DonationButton />
      </div>
    </div>
    </div>
  </div>
</section>
