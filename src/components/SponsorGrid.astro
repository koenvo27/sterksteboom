---
import sponsors from "../data/sponsors.json";
import EmptyState from "./EmptyState.astro";

interface Sponsor {
  name: string;
  logo: string;
  website?: string;
  description?: string;
  supportType: string;
  level?: string;
  featured?: boolean;
  order?: number;
}

const list = (sponsors as Sponsor[]).slice().sort((a, b) => (a.order ?? 99) - (b.order ?? 99));
---

{list.length === 0 ? (
  <EmptyState
    message="Binnenkort verschijnen hier de bedrijven en organisaties die mee hun schouders onder dit project zetten."
    ctaLabel="Word partner"
    ctaHref="/word-partner"
  />
) : (
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
    {list.map((sponsor) => (
      <a
        href={sponsor.website ?? "#"}
        target={sponsor.website ? "_blank" : undefined}
        rel={sponsor.website ? "noopener noreferrer" : undefined}
        class="flex items-center justify-center rounded-card border border-beige-200 bg-white p-6 h-28 hover:border-goud-500 transition-colors"
        aria-label={sponsor.name}
      >
        <img
          src={sponsor.logo}
          alt={sponsor.name}
          class="max-h-14 max-w-full object-contain"
          loading="lazy"
          width="160"
          height="56"
        />
      </a>
    ))}
  </div>
)}
