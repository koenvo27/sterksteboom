---
import { footerNav } from "../data/navigation";
import { siteConfig } from "../data/site-config";

const year = new Date().getFullYear();
---

<footer class="bg-antraciet-900 text-beige-100 mt-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <a href="/" class="flex items-center gap-3 font-display text-lg font-semibold text-beige-50">
        <img src="/favicon.svg" alt="" width="32" height="32" class="rounded-md" />
        {siteConfig.projectName}
      </a>
      <p class="mt-4 max-w-sm text-sm text-beige-200">
        {siteConfig.tagline}
      </p>
      <div class="mt-6">
        <a href={siteConfig.donationUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-goud-500 text-antraciet-900 font-semibold px-5 py-2.5 text-sm">
          Steun het project ↗
        </a>
      </div>
    </div>

    <div>
      <h2 class="font-display text-sm uppercase tracking-wide text-goud-300 mb-4">Navigatie</h2>
      <ul class="space-y-2 text-sm">
        {footerNav.slice(0, 8).map((item) => (
          <li><a href={item.href} class="hover:text-goud-300">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h2 class="font-display text-sm uppercase tracking-wide text-goud-300 mb-4">Contact</h2>
      <ul class="space-y-2 text-sm">
        <li>
          <a href={`mailto:${siteConfig.email}`} class="hover:text-goud-300 break-all">{siteConfig.email}</a>
        </li>
        <li>
          <a href={siteConfig.facebookUrl} target="_blank" rel="noopener noreferrer" class="hover:text-goud-300">Facebook ↗</a>
        </li>
      </ul>
      <ul class="mt-6 space-y-2 text-xs text-beige-200">
        <li><a href="/privacy" class="hover:text-goud-300">Privacyverklaring</a></li>
        <li><a href="/cookies" class="hover:text-goud-300">Cookiebeleid</a></li>
        <li><a href="/disclaimer" class="hover:text-goud-300">Disclaimer</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-antraciet-700">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-6 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between text-xs text-beige-200">
      <p class="max-w-2xl">
        {siteConfig.projectName} is een persoonlijk initiatief ten voordele van Kom op tegen Kanker. Donaties verlopen via de officiële actiepagina van Kom op tegen Kanker.
      </p>
      <p>&copy; {year} {siteConfig.projectName}</p>
    </div>
  </div>
</footer>
