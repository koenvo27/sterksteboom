---
// De reis — verticale tijdlijn, gevoed door src/data/journey.ts.
// Rustig en mobiel-first: één doorlopende "groeilijn" met stappen erlangs.
//
// variant "full"       -> volledige tijdlijn met tagline + beschrijving.
// variant "highlights" -> compacte homepage-versie: enkel de stappen met
//                         homepage:true, zonder de lange beschrijving.
import { journeyWithStatus } from "../data/journey";

interface Props {
  variant?: "full" | "highlights";
}
const { variant = "full" } = Astro.props;

const all = journeyWithStatus();
const steps = variant === "highlights" ? all.filter((s) => s.homepage) : all;
const compact = variant === "highlights";
---

<div class="relative mx-auto max-w-2xl">
  <!-- Doorlopende groeilijn (het jaarring-/boommotief als tijdlijn). Decoratief. -->
  <div
    class="absolute left-5 sm:left-6 top-4 bottom-4 w-px bg-gradient-to-b from-beige-200 via-goud-300 to-beige-200"
    aria-hidden="true"
  >
  </div>

  <ol class="space-y-8 sm:space-y-12">
    {steps.map((step) => (
      <li class="relative pl-16 sm:pl-20">
        <span
          class:list={[
            "absolute left-0 top-0 flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center rounded-full border text-lg sm:text-xl",
            step.status === "done"
              ? "bg-goud-100 border-goud-500"
              : step.status === "current"
                ? "bg-beige-50 border-goud-500 ring-4 ring-goud-100"
                : "bg-beige-50 border-beige-200",
          ]}
          aria-hidden="true"
        >
          {step.icon}
        </span>

        <p class="text-xs font-semibold uppercase tracking-wide text-bos-600">
          {step.label}
          {step.status === "current" && (
            <span class="ml-1 rounded-full bg-goud-100 px-2 py-0.5 text-bos-600">nu</span>
          )}
        </p>
        <h3 class="mt-1 font-display text-xl font-semibold text-antraciet-900">{step.title}</h3>
        {!compact && step.tagline && (
          <p class="mt-1.5 font-medium text-antraciet-900">{step.tagline}</p>
        )}
        {!compact && step.description && (
          <p class="mt-1 text-antraciet-700 leading-relaxed">{step.description}</p>
        )}
      </li>
    ))}
  </ol>
</div>
