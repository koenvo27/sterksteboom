---
import { siteConfig } from "../data/site-config";
import Button from "./Button.astro";

interface Props {
  categories?: string[];
  subject: string;
}

const { categories, subject } = Astro.props;
const hasEndpoint = siteConfig.formEndpoint.trim().length > 0;
const mailHref = `mailto:${siteConfig.email}?subject=${encodeURIComponent(subject)}`;
// Absolute URL voor de redirect na verzenden (FormSubmit vereist absoluut).
const bedanktUrl = new URL("/bedankt", siteConfig.url).toString();
// Cloudflare Turnstile: enkel tonen als er een site key ingesteld is.
const turnstileKey = siteConfig.turnstileSiteKey?.trim() ?? "";
const hasTurnstile = turnstileKey.length > 0;

// Submit-bewaking: blokkeer versturen tot Turnstile opgelost is. Als de widget
// niet kon laden (bv. Cloudflare onbereikbaar), laten we versturen gewoon toe —
// we sluiten echte bezoekers nooit buiten. In een string gezet zodat de accolades
// niet als Astro-expressies gelezen worden.
const turnstileGuard = `
  document.addEventListener("submit", function (e) {
    var form = e.target;
    if (!(form instanceof HTMLFormElement)) return;
    var widget = form.querySelector(".cf-turnstile");
    if (!widget) return;
    var field = form.querySelector('[name="cf-turnstile-response"]');
    if (field && !field.value) {
      e.preventDefault();
      var err = document.getElementById("turnstile-error");
      if (err) err.classList.remove("hidden");
      widget.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  });
`;
---

{hasEndpoint ? (
  <form
    action={siteConfig.formEndpoint}
    method="POST"
    class="grid gap-5 max-w-xl"
  >
    <!-- FormSubmit-instellingen: onderwerp, nette tabelweergave in de mail,
         redirect naar de bedankpagina, en een honeypot tegen spam.
         _captcha=false: FormSubmit's eigen (Google reCAPTCHA) captcha staat uit;
         we gebruiken Cloudflare Turnstile hieronder — cookievrij en zonder Google. -->
    <input type="hidden" name="_subject" value={subject} />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_next" value={bedanktUrl} />
    <input type="hidden" name="_captcha" value="false" />
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
    <div>
      <label for="name" class="block text-sm font-semibold text-antraciet-900 mb-1">Naam</label>
      <input id="name" name="name" type="text" required
        class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white" />
    </div>
    <div>
      <label for="email" class="block text-sm font-semibold text-antraciet-900 mb-1">E-mailadres</label>
      <input id="email" name="email" type="email" required
        class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white" />
    </div>
    {categories && (
      <div>
        <label for="category" class="block text-sm font-semibold text-antraciet-900 mb-1">Onderwerp</label>
        <select id="category" name="category" required class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white">
          {categories.map((cat) => <option value={cat}>{cat}</option>)}
        </select>
      </div>
    )}
    <div>
      <label for="message" class="block text-sm font-semibold text-antraciet-900 mb-1">Bericht</label>
      <textarea id="message" name="message" rows="5" required
        class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white"></textarea>
    </div>
    <div class="flex items-start gap-3">
      <input id="privacy" name="privacy" type="checkbox" required class="mt-1" />
      <label for="privacy" class="text-sm text-antraciet-700">
        Ik ga akkoord dat mijn gegevens gebruikt worden om mijn vraag te beantwoorden. Zie de <a href="/privacy" class="underline">privacyverklaring</a>.
      </label>
    </div>
    {hasTurnstile && (
      <div>
        <!-- Cloudflare Turnstile: cookievrije spamcontrole. De widget vult zelf
             een verborgen veld 'cf-turnstile-response' in bij succes. -->
        <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="auto" data-language="nl"></div>
        <p id="turnstile-error" class="mt-2 hidden text-sm text-red-700" role="alert">
          Bevestig even dat je geen robot bent voor je verstuurt.
        </p>
      </div>
    )}

    <button type="submit" class="inline-flex items-center justify-center rounded-full bg-goud-500 text-antraciet-900 font-semibold px-6 py-3 min-h-11 w-fit">
      Versturen
    </button>
    <p class="text-xs text-antraciet-500">
      Na verzending word je doorgestuurd naar een bevestigingspagina. Bij een fout blijft dit
      formulier zichtbaar zodat je opnieuw kan proberen.
    </p>
  </form>
) : (
  <div class="rounded-card border border-beige-200 bg-beige-100/60 p-6 max-w-xl">
    <p class="text-antraciet-700">
      Er is momenteel geen online formulier gekoppeld. Stuur gerust rechtstreeks een e-mail — die komt bij Koen terecht.
    </p>
    <div class="mt-5">
      <Button href={mailHref} variant="secondary">Stuur een e-mail</Button>
    </div>
  </div>
)}

{hasEndpoint && hasTurnstile && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}
{hasEndpoint && hasTurnstile && <script is:inline set:html={turnstileGuard} />}
