---
import { siteConfig } from "../data/site-config";
import Button from "./Button.astro";

interface Props {
  categories?: string[];
  subject: string;
}

const { categories, subject } = Astro.props;
const hasEndpoint = siteConfig.formEndpoint.trim().length > 0;
const mailHref = `mailto:${siteConfig.email}?subject=${encodeURIComponent(subject)}`;
// Absolute URL voor de redirect na verzenden (FormSubmit vereist absoluut).
const bedanktUrl = new URL("/bedankt", siteConfig.url).toString();
---

{hasEndpoint ? (
  <form
    action={siteConfig.formEndpoint}
    method="POST"
    class="grid gap-5 max-w-xl"
  >
    <!-- FormSubmit-instellingen: onderwerp, nette tabelweergave in de mail en
         redirect naar de bedankpagina. FormSubmit's eigen captcha (reCAPTCHA)
         blijft bewust actief (we zetten _captcha NIET op false). De honeypot en
         een beperkte blacklist vangen bijkomende spam op. -->
    <input type="hidden" name="_subject" value={subject} />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_next" value={bedanktUrl} />
    <!-- Zeer beperkte blacklist: enkel ondubbelzinnige spamtermen die niet in
         geldige (Nederlandstalige) berichten voorkomen. -->
    <input type="hidden" name="_blacklist" value="viagra, casino" />
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
    <div>
      <label for="name" class="block text-sm font-semibold text-antraciet-900 mb-1">Naam</label>
      <input id="name" name="name" type="text" required maxlength="100"
        class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white" />
    </div>
    <div>
      <label for="email" class="block text-sm font-semibold text-antraciet-900 mb-1">E-mailadres</label>
      <input id="email" name="email" type="email" required maxlength="150"
        class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white" />
    </div>
    {categories && (
      <div>
        <label for="category" class="block text-sm font-semibold text-antraciet-900 mb-1">Onderwerp</label>
        <select id="category" name="category" required class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white">
          {categories.map((cat) => <option value={cat}>{cat}</option>)}
        </select>
      </div>
    )}
    <div>
      <label for="message" class="block text-sm font-semibold text-antraciet-900 mb-1">Bericht</label>
      <textarea id="message" name="message" rows="5" required maxlength="5000"
        class="w-full rounded-lg border border-beige-200 px-4 py-3 bg-white"></textarea>
    </div>
    <div class="flex items-start gap-3">
      <input id="privacy" name="privacy" type="checkbox" required class="mt-1" />
      <label for="privacy" class="text-sm text-antraciet-700">
        Ik ga akkoord dat mijn gegevens gebruikt worden om mijn vraag te beantwoorden. Zie de <a href="/privacy" class="underline">privacyverklaring</a>.
      </label>
    </div>
    <button type="submit" class="inline-flex items-center justify-center rounded-full bg-goud-500 text-antraciet-900 font-semibold px-6 py-3 min-h-11 w-fit">
      Versturen
    </button>
    <p class="text-xs text-antraciet-500">
      Na verzending volgt een korte spamcontrole en word je doorgestuurd naar een
      bevestigingspagina. Bij een fout blijft dit formulier zichtbaar zodat je opnieuw kan proberen.
    </p>
  </form>
) : (
  <div class="rounded-card border border-beige-200 bg-beige-100/60 p-6 max-w-xl">
    <p class="text-antraciet-700">
      Er is momenteel geen online formulier gekoppeld. Stuur gerust rechtstreeks een e-mail — die komt bij Koen terecht.
    </p>
    <div class="mt-5">
      <Button href={mailHref} variant="secondary">Stuur een e-mail</Button>
    </div>
  </div>
)}
