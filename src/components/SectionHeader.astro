---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" ? "mx-auto text-center" : ""]}>
  {eyebrow && (
    <p class="font-body text-sm font-semibold uppercase tracking-wide text-bos-600 mb-2">{eyebrow}</p>
  )}
  <h2 class="font-display text-3xl sm:text-4xl font-semibold text-antraciet-900">{title}</h2>
  {description && <p class="mt-3 text-antraciet-700">{description}</p>}
</div>
