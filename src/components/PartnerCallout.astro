---
import Button from "./Button.astro";
---

<section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
  <div class="rounded-card border border-goud-300 bg-goud-50 p-8 sm:p-12 grid gap-6 md:grid-cols-[1fr_auto] items-center">
    <div>
      <h2 class="font-display text-2xl sm:text-3xl font-semibold text-antraciet-900">Word partner van dit project</h2>
      <p class="mt-2 text-antraciet-700 max-w-xl">
        Bedrijven en organisaties kunnen op verschillende manieren mee hun schouders zetten onder De Sterkste Boom van Rendestede.
      </p>
    </div>
    <Button href="/word-partner" variant="secondary">Ontdek de mogelijkheden</Button>
  </div>
</section>
