---
import Button from "./Button.astro";
import { siteConfig } from "../data/site-config";

interface Props {
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
  label?: string;
}

const { variant = "primary", class: className = "", label = "Steun het project" } = Astro.props;
---

<Button href={siteConfig.donationUrl} variant={variant} external class={className}>
  {label}
</Button>
