---
import { mainNav } from "../data/navigation";
import { siteConfig } from "../data/site-config";
import DonationButton from "./DonationButton.astro";
import MobileNavigation from "./MobileNavigation.astro";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<!-- Geen backdrop-blur hier: een backdrop-filter maakt de header het
     referentiekader voor position:fixed, waardoor het mobiele menu-overlay
     (dat in de header staat) op hoogte 0 zou uitkomen. -->
<header class="sticky top-0 z-50 bg-beige-50 border-b border-beige-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex h-16 sm:h-20 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 font-display text-base sm:text-lg font-semibold text-antraciet-900 shrink-0">
        <img src="/images/tree-mark.webp" alt="" width="40" height="40" class="shrink-0" />
        <span class="leading-tight">
          De Sterkste Boom<br class="hidden sm:block" /> van Rendestede
        </span>
      </a>

      <nav aria-label="Hoofdnavigatie" class="hidden xl:flex items-center gap-5 font-body text-sm">
        {mainNav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "py-2 border-b-2 transition-colors whitespace-nowrap",
              isActive(item.href)
                ? "border-goud-500 text-antraciet-900 font-semibold"
                : "border-transparent text-antraciet-700 hover:text-antraciet-900 hover:border-goud-300",
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden xl:block shrink-0">
        <DonationButton />
      </div>

      <MobileNavigation navItems={mainNav} donationUrl={siteConfig.donationUrl} />
    </div>
  </div>
</header>
