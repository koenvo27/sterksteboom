---
import { siteConfig } from "../data/site-config";

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;

// BreadcrumbList voor zoekmachines: Home + de doorgegeven kruimels.
const trail = [{ label: "Home", href: "/" }, ...items];
const breadcrumbJson = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: trail.map((crumb, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: crumb.label,
    ...(crumb.href ? { item: new URL(crumb.href, siteConfig.url).toString() } : {}),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />


<nav aria-label="Broodkruimel" class="text-sm text-antraciet-500 mb-8">
  <ol class="flex flex-wrap items-center gap-2">
    <li><a href="/" class="hover:text-goud-700">Home</a></li>
    {items.map((item) => (
      <li class="flex items-center gap-2">
        <span aria-hidden="true">/</span>
        {item.href ? (
          <a href={item.href} class="hover:text-goud-700">{item.label}</a>
        ) : (
          <span aria-current="page" class="text-antraciet-900 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
