---
interface Props {
  title: string;
  summary: string;
  date: Date;
  category: string;
  href: string;
}

const { title, summary, date, category, href } = Astro.props;
const formattedDate = date.toLocaleDateString("nl-BE", { day: "numeric", month: "long", year: "numeric" });
---

<a href={href} class="group flex flex-col rounded-card border border-beige-200 bg-white p-6 hover:border-goud-500 transition-colors h-full">
  <span class="inline-block text-xs font-semibold uppercase tracking-wide text-bos-600 mb-2">{category}</span>
  <h3 class="font-display text-xl font-semibold text-antraciet-900 group-hover:text-goud-700">{title}</h3>
  <p class="mt-2 text-antraciet-700 text-sm flex-1">{summary}</p>
  <p class="mt-4 text-xs text-antraciet-500">{formattedDate}</p>
</a>
