---
interface Props {
  title: string;
  type: string;
  summary: string;
  date: Date;
  location?: string;
  status: "Aankomend" | "Afgelopen";
  externalUrl?: string;
}

const { title, type, summary, date, location, status, externalUrl } = Astro.props;
const formattedDate = date.toLocaleDateString("nl-BE", { day: "numeric", month: "long", year: "numeric" });
---

<div class:list={["rounded-card border border-beige-200 bg-white p-6", status === "Afgelopen" ? "opacity-70" : ""]}>
  <span class="inline-block text-xs font-semibold uppercase tracking-wide text-bos-600 mb-1">{type}</span>
  <h3 class="font-display text-lg font-semibold text-antraciet-900">{title}</h3>
  <p class="mt-1 text-sm text-antraciet-500">{formattedDate}{location ? ` · ${location}` : ""}</p>
  <p class="mt-2 text-antraciet-700 text-sm">{summary}</p>
  {externalUrl && (
    <a href={externalUrl} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-sm font-semibold text-goud-700 hover:underline">
      Meer info ↗
    </a>
  )}
</div>
